{
  "name": "@thawee/pi-custom-models-workspace",
  "version": "1.2.5",
  "description": "Pi Custom Models Suite: Sync models from OpenAI-compatible APIs or manage models on llama.cpp router mode",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extensions",
    "openai",
    "custom-models",
    "llama"
  ],
  "license": "MIT",
  "author": "thawee",
  "homepage": "https://github.com/thawee/pi-custom-models",
  "repository": {
    "type": "git",
    "url": "https://github.com/thawee/pi-custom-models"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "build": "./scripts/build-tgz.sh"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "individual-packages/*"
  ],
  "pi": {
    "extensions": [
      "./extensions"
